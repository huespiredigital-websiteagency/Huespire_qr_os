# =========================================================================
# RESTAURANT OS - MONOREPO ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to:
#   - apps/backend/.env
#   - apps/frontend/.env.local
# =========================================================================

# -------------------------------------------------------------------------
# BACKEND SERVICES (.env)
# -------------------------------------------------------------------------
NODE_ENV=development
PORT=5000

# Prisma Database Configuration (Points to the Docker PostgreSQL container)
DATABASE_URL=postgresql://postgres:password@localhost:5435/restaurant_os?schema=public

# Cache Store (Points to the Docker Redis container)
REDIS_URL=redis://localhost:6379

# JWT and Security Keys
JWT_SECRET=your-super-secret-key-change-in-production
BETTER_AUTH_SECRET=your-better-auth-secret-change-in-production
BETTER_AUTH_URL=http://localhost:5000

# Resend Email Integration (Optional Placeholder)
RESEND_API_KEY=re_123456789
SMTP_FROM=no-reply@restaurantos.local

# Redirection URLs (Use localhost or nip.io for mobile device testing)
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# -------------------------------------------------------------------------
# FRONTEND CONFIGURATION (.env.local)
# -------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Restaurant OS"

# Local/Network API URLs (Must point to the running backend port)
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# Base Platform Domain
NEXT_PUBLIC_DOMAIN=localhost:3000
