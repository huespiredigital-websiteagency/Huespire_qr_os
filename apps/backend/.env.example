# NestJS Backend Environment Configuration
NODE_ENV=development
PORT=5000

# Database & Cache
DATABASE_URL=postgresql://postgres:password@localhost:5435/restaurant_os?schema=public
REDIS_URL=redis://localhost:6379

# Auth Keys
JWT_SECRET=your-super-secret-key-change-in-production
BETTER_AUTH_SECRET=your-better-auth-secret-change-in-production
BETTER_AUTH_URL=http://localhost:5000

# Communication & Assets
RESEND_API_KEY=re_123456789
SMTP_FROM=no-reply@restaurantos.local

# Service Routing
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
