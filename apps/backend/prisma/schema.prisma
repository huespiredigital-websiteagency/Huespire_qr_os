datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRED
  SUSPENDED
  CANCELLED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
  OUT_OF_SERVICE
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  ONLINE
  OTHER
}

enum BillStatus {
  OPEN
  PAID
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model Plan {
  id                  String         @id @default(uuid())
  name                String         @unique
  code                String         @unique
  description         String?
  setupFee            Decimal        @db.Decimal(10, 2)
  monthlyPrice        Decimal        @db.Decimal(10, 2)
  maxTables           Int            @default(20)
  maxStaff            Int            @default(5)
  monthlyEmailLimit   Int            @default(1000)
  customDomain        Boolean        @default(false)
  analyticsEnabled    Boolean        @default(true)
  prioritySupport     Boolean        @default(false)
  isActive            Boolean        @default(true)
  displayOrder        Int            @default(1)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  subscriptions       Subscription[]

  @@index([isActive])
  @@index([displayOrder])
  @@map("plans")
}

model Subscription {
  id                  String             @id @default(uuid())
  restaurantId        String             @unique
  restaurant          Restaurant         @relation(fields: [restaurantId], references: [id])
  planId              String
  plan                Plan               @relation(fields: [planId], references: [id])
  status              SubscriptionStatus @default(ACTIVE)
  billingCycle        BillingCycle       @default(MONTHLY)
  startDate           DateTime           @default(now())
  endDate             DateTime
  nextBillingDate     DateTime
  monthlyPrice        Decimal            @db.Decimal(10, 2)
  setupFee            Decimal            @db.Decimal(10, 2)
  maxTables           Int                @default(20)
  maxStaff            Int                @default(5)
  monthlyEmailLimit   Int                @default(1000)
  currentEmailUsage   Int                @default(0)
  isAutoRenew         Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}

model Restaurant {
  id             String              @id @default(uuid())
  name           String
  slug           String              @unique
  email          String
  phone          String
  address        String?
  city           String?
  state          String?
  country        String?
  postalCode     String?
  logoUrl        String?
  coverImageUrl  String?
  subdomain      String              @unique
  customDomain   String?             @unique
  domain         String?             @unique
  timezone       String              @default("Asia/Kolkata")
  currency       String              @default("INR")
  taxPercentage  Decimal             @default(0.00) @db.Decimal(5, 2)
  isActive       Boolean             @default(true)
  emailVerified  Boolean             @default(false)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?
  
  users          User[]
  tables         Table[]
  qrCodes        QRCode[]
  categories     Category[]
  menuItems      MenuItem[]
  menuImages     MenuImage[]
  addons         Addon[]
  variants       Variant[]
  customers      Customer[]
  orders         Order[]
  payments       Payment[]
  bills          Bill[]
  coupons        Coupon[]
  notifications  Notification[]
  auditLogs      AuditLog[]
  settings       RestaurantSettings?
  subscription   Subscription?
  tableSessions  TableSession[]
  emailLogs      EmailLog[]

  @@index([subdomain])
  @@index([domain])
  @@index([email])
  @@index([isActive])
  @@index([deletedAt])
  @@map("restaurants")
}

model RestaurantSettings {
  id                         String      @id @default(uuid())
  restaurantId               String      @unique
  restaurant                 Restaurant  @relation(fields: [restaurantId], references: [id])
  timezone                   String      @default("Asia/Kolkata")
  currency                   String      @default("INR")
  taxPercentage              Decimal     @default(0.00) @db.Decimal(5, 2)
  orderPrefix                String      @default("ORD-")
  receiptFooter              String?
  theme                      String      @default("light")
  
  // Branding settings
  primaryColor               String      @default("#6366f1")
  secondaryColor             String      @default("#10b981")
  businessEmail              String?
  businessPhone              String?
  businessRegistrationNumber String?
  gstVatNumber               String?
  address                    String?
  city                       String?
  state                      String?
  country                    String?
  postalCode                 String?
  language                   String      @default("en")
  businessHours              String?
  invoicePrefix              String      @default("INV-")
  invoiceFooter              String?
  emailFooter                String?
  website                    String?
  socialLinks                String?
  enableEmailReceipts        Boolean     @default(true)
  enableOnlineOrdering       Boolean     @default(true)
  enableTableOrdering        Boolean     @default(true)
  enableTakeaway             Boolean     @default(true)
  enableDelivery             Boolean     @default(true)

  createdAt                  DateTime    @default(now())
  updatedAt                  DateTime    @updatedAt

  @@map("restaurant_settings")
}



model Role {
  id           String    @id @default(uuid())
  name         String    @unique
  code         String    @unique
  description  String?
  isSystem     Boolean   @default(true)
  displayOrder Int       @default(1)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  users        User[]

  @@index([code])
  @@map("roles")
}

model User {
  id             String         @id @default(uuid())
  restaurantId   String?
  restaurant     Restaurant?    @relation(fields: [restaurantId], references: [id])
  roleId         String
  role           Role           @relation(fields: [roleId], references: [id])
  firstName      String
  lastName       String?
  email          String
  phone          String?
  passwordHash   String
  avatarUrl      String?
  lastLoginAt    DateTime?
  emailVerified  Boolean        @default(false)
  isActive       Boolean        @default(true)
  status         String         @default("ACTIVE")
  invitedById    String?
  invitedBy      User?          @relation("UserInvitedBy", fields: [invitedById], references: [id])
  invitedUsers   User[]         @relation("UserInvitedBy")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  
  auditLogs      AuditLog[]
  notifications  Notification[]
  sessions       Session[]
  resetTokens    PasswordResetToken[]
  verifyTokens   VerificationToken[]
  receivedPayments Payment[]   @relation("ReceivedPayments")

  @@unique([restaurantId, email])
  @@index([restaurantId])
  @@index([roleId])
  @@index([email])
  @@index([isActive])
  @@index([restaurantId, roleId])
  @@index([restaurantId, deletedAt])
  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@map("sessions")
}

model VerificationToken {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model Table {
  id              String      @id @default(uuid())
  restaurantId    String
  restaurant      Restaurant  @relation(fields: [restaurantId], references: [id])
  tableNumber     Int
  tableName       String
  seatingCapacity Int         @default(4)
  qrCodeId        String?     @unique
  status          TableStatus @default(AVAILABLE)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  notes           String?
  
  qrCode          QRCode?     @relation("TableQRCode")
  orders          Order[]
  tableSessions   TableSession[]

  @@unique([restaurantId, tableNumber])
  @@index([restaurantId])
  @@index([status])
  @@index([restaurantId, status])
  @@index([restaurantId, deletedAt])
  @@map("tables")
}

model QRCode {
  id             String      @id @default(uuid())
  restaurantId   String
  restaurant     Restaurant  @relation(fields: [restaurantId], references: [id])
  tableId        String      @unique
  table          Table       @relation("TableQRCode", fields: [tableId], references: [id])
  qrToken        String      @unique
  qrPath         String
  qrUrl          String
  scanCount      Int         @default(0)
  lastScannedAt  DateTime?
  isActive       Boolean     @default(true)
  generatedAt    DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([restaurantId])
  @@index([qrToken])
  @@map("qr_codes")
}

model Category {
  id           String      @id @default(uuid())
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  name         String
  slug         String
  description  String?
  imageUrl     String?
  displayOrder Int         @default(1)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
  
  menuItems      MenuItem[]
  categoryAddons CategoryAddon[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([displayOrder])
  @@index([restaurantId, isActive])
  @@index([restaurantId, deletedAt])
  @@map("categories")
}

model MenuItem {
  id              String      @id @default(uuid())
  restaurantId    String
  restaurant      Restaurant  @relation(fields: [restaurantId], references: [id])
  categoryId      String
  category        Category    @relation(fields: [categoryId], references: [id])
  name            String
  slug            String
  description     String?
  imageUrl        String?
  sku             String?
  price           Decimal     @db.Decimal(10, 2)
  taxPercentage   Decimal     @default(0.00) @db.Decimal(5, 2)
  preparationTime Int         @default(15)
  calories        Int?
  isVeg           Boolean     @default(false)
  isVegan         Boolean     @default(false)
  isSpicy         Boolean     @default(false)
  isAvailable     Boolean     @default(true)
  displayOrder    Int         @default(1)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  
  orderItems      OrderItem[]
  images          MenuImage[]
  variants        Variant[]
  menuItemAddons  MenuItemAddon[]

  @@unique([restaurantId, sku])
  @@index([restaurantId])
  @@index([categoryId])
  @@index([isAvailable])
  @@index([displayOrder])
  @@index([restaurantId, categoryId, isAvailable])
  @@index([restaurantId, isAvailable])
  @@index([restaurantId, deletedAt])
  @@map("menu_items")
}

model MenuImage {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  menuItemId   String
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id])
  imageName    String
  imagePath    String
  imageUrl     String
  fileSize     Int?
  mimeType     String
  width        Int?
  height       Int?
  displayOrder Int        @default(1)
  isPrimary    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  @@index([restaurantId])
  @@index([menuItemId])
  @@index([restaurantId, menuItemId])
  @@map("menu_images")
}

model Addon {
  id              String     @id @default(uuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])
  name            String
  description     String?
  additionalPrice Decimal    @db.Decimal(10, 2)
  displayOrder    Int        @default(1)
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  orderItemAddons OrderItemAddon[]
  menuItemAddons  MenuItemAddon[]
  categoryAddons  CategoryAddon[]

  @@index([restaurantId])
  @@index([restaurantId, isActive])
  @@map("addons")
}

model MenuItemAddon {
  id         String   @id @default(uuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  addonId    String
  addon      Addon    @relation(fields: [addonId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([menuItemId, addonId])
  @@index([menuItemId])
  @@index([addonId])
  @@map("menu_item_addons")
}

model CategoryAddon {
  id         String   @id @default(uuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  addonId    String
  addon      Addon    @relation(fields: [addonId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([categoryId, addonId])
  @@index([categoryId])
  @@index([addonId])
  @@map("category_addons")
}

model Variant {
  id              String     @id @default(uuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])
  menuItemId      String
  menuItem        MenuItem   @relation(fields: [menuItemId], references: [id])
  name            String
  price           Decimal    @db.Decimal(10, 2)
  preparationTime Int        @default(15)
  isAvailable     Boolean    @default(true)
  displayOrder    Int        @default(1)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  orderItemVariants OrderItemVariant[]

  @@index([restaurantId])
  @@index([menuItemId])
  @@index([restaurantId, menuItemId])
  @@index([restaurantId, isAvailable])
  @@map("variants")
}

model Customer {
  id            String     @id @default(uuid())
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
  name          String
  phone         String
  email         String?
  totalOrders   Int        @default(0)
  totalSpent    Decimal    @default(0.00) @db.Decimal(10, 2)
  loyaltyPoints Int        @default(0)
  notes         String?
  vipStatus     Boolean    @default(false)
  tags          String?
  lastVisitAt   DateTime?
  favoriteItems String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  orders        Order[]

  @@unique([restaurantId, phone])
  @@index([restaurantId])
  @@index([restaurantId, name])
  @@map("customers")
}

model Order {
  id            String        @id @default(uuid())
  restaurantId  String
  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id])
  tableId       String
  table         Table         @relation(fields: [tableId], references: [id])
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  orderNumber   String
  subtotal      Decimal       @db.Decimal(10, 2)
  tax           Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0.00) @db.Decimal(10, 2)
  totalAmount   Decimal       @db.Decimal(10, 2)
  paymentStatus PaymentStatus @default(PENDING)
  orderStatus   OrderStatus   @default(PENDING)
  notes         String?
  rejectionReason String?

  // Lifecycle Timestamps & Analytics
  acceptedAt         DateTime?
  preparingStartedAt DateTime?
  readyAt            DateTime?
  pickedUpAt         DateTime?
  servedAt           DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?

  // Staff Action Tracking IDs
  acceptedById         String?
  preparingStartedById String?
  readyById            String?
  pickedUpById         String?
  servedById           String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  sessionId     String?
  session       TableSession? @relation(fields: [sessionId], references: [id])

  orderItems    OrderItem[]
  payment       Payment?

  @@index([restaurantId])
  @@index([sessionId])
  @@index([customerId])
  @@index([tableId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([restaurantId, sessionId])
  @@index([restaurantId, customerId])
  @@index([restaurantId, orderStatus])
  @@index([restaurantId, createdAt])
  @@index([customerId, createdAt])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  tax        Decimal  @db.Decimal(10, 2)
  subtotal   Decimal  @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime @default(now())

  variants   OrderItemVariant[]
  addons     OrderItemAddon[]

  @@index([orderId])
  @@index([menuItemId])
  @@index([orderId, menuItemId])
  @@map("order_items")
}

model OrderItemVariant {
  id           String    @id @default(uuid())
  orderItemId  String
  orderItem    OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  variantId    String
  variant      Variant   @relation(fields: [variantId], references: [id])
  name         String
  price        Decimal   @db.Decimal(10, 2)

  @@index([orderItemId])
  @@map("order_item_variants")
}

model OrderItemAddon {
  id              String    @id @default(uuid())
  orderItemId     String
  orderItem       OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  addonId         String
  addon           Addon     @relation(fields: [addonId], references: [id])
  name            String
  additionalPrice Decimal   @db.Decimal(10, 2)

  @@index([orderItemId])
  @@map("order_item_addons")
}

model Bill {
  id             String       @id @default(uuid())
  restaurantId   String
  restaurant     Restaurant   @relation(fields: [restaurantId], references: [id])
  tableSessionId String
  tableSession   TableSession @relation(fields: [tableSessionId], references: [id], onDelete: Cascade)
  billNumber     String
  subtotal       Decimal      @db.Decimal(10, 2)
  taxAmount      Decimal      @db.Decimal(10, 2)
  discountAmount Decimal      @default(0.00) @db.Decimal(10, 2)
  grandTotal     Decimal      @db.Decimal(10, 2)
  status         BillStatus   @default(OPEN)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  payments       Payment[]

  @@unique([restaurantId, billNumber])
  @@index([restaurantId])
  @@index([tableSessionId])
  @@index([status])
  @@map("bills")
}

model Payment {
  id                   String        @id @default(uuid())
  restaurantId         String
  restaurant           Restaurant    @relation(fields: [restaurantId], references: [id])
  tableSessionId       String
  tableSession         TableSession  @relation(fields: [tableSessionId], references: [id], onDelete: Cascade)
  billId               String?
  bill                 Bill?         @relation(fields: [billId], references: [id], onDelete: SetNull)
  orderId              String?       @unique
  order                Order?        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentMethod        PaymentMethod
  paymentStatus        PaymentStatus @default(PENDING)
  amount               Decimal       @db.Decimal(10, 2)
  amountReceived       Decimal?      @db.Decimal(10, 2)
  changeGiven          Decimal?      @db.Decimal(10, 2)
  transactionReference String?
  receivedById         String?
  receivedBy           User?         @relation("ReceivedPayments", fields: [receivedById], references: [id], onDelete: SetNull)
  paidAt               DateTime?
  notes                String?
  createdAt            DateTime      @default(now())

  @@index([restaurantId])
  @@index([tableSessionId])
  @@index([billId])
  @@index([receivedById])
  @@index([paymentStatus])
  @@index([paymentMethod])
  @@map("payments")
}

model Coupon {
  id           String       @id @default(uuid())
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id])
  code         String
  discountType DiscountType @default(PERCENTAGE)
  discountValue Decimal     @db.Decimal(10, 2)
  minimumOrder Decimal      @default(0.00) @db.Decimal(10, 2)
  expiryDate   DateTime
  usageLimit   Int?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([restaurantId, code])
  @@index([restaurantId])
  @@map("coupons")
}

model Notification {
  id           String      @id @default(uuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  userId       String?
  user         User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String
  title        String
  message      String
  status       String      @default("UNREAD")
  sentAt       DateTime?
  createdAt    DateTime    @default(now())

  @@index([restaurantId])
  @@index([userId])
  @@map("notifications")
}

model AuditLog {
  id           String      @id @default(uuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  userId       String?
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action       String
  entity       String
  entityId     String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime    @default(now())

  @@index([restaurantId])
  @@index([userId])
  @@map("audit_logs")
}

enum TableSessionStatus {
  OPEN
  CLOSED
}

model TableSession {
  id             String             @id @default(uuid())
  restaurantId   String
  restaurant     Restaurant         @relation(fields: [restaurantId], references: [id])
  tableId        String
  table          Table              @relation(fields: [tableId], references: [id])
  sessionNumber  String
  status         TableSessionStatus @default(OPEN)
  openedAt       DateTime           @default(now())
  closedAt       DateTime?
  openedBy       String?
  closedBy       String?
  totalAmount    Decimal            @default(0.00) @db.Decimal(10, 2)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  
  orders         Order[]
  bills          Bill[]
  payments       Payment[]

  @@index([restaurantId])
  @@index([tableId])
  @@index([status])
  @@index([restaurantId, status])
  @@index([tableId, status])
  @@map("table_sessions")
}

model EmailLog {
  id           String      @id @default(uuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  recipient    String
  sender       String
  subject      String
  status       String      @default("PENDING") // DELIVERED, PENDING, FAILED, OPENED
  errorMessage String?
  attempts     Int         @default(1)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([restaurantId])
  @@index([status])
  @@map("email_logs")
}
